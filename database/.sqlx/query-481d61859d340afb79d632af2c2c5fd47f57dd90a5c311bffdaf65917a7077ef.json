  "query": "\n            SELECT id, user_id, ip_address as \"ip_address: IpAddr\", expires_at, created_at, revoked_at\n            FROM user_sessions\n            WHERE id = $1\n            AND revoked_at IS NULL\n            AND expires_at >= NOW()\n            LIMIT 1\n            ",
